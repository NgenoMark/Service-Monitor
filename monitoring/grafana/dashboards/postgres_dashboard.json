          "rawSql": "SELECT\r\n  date_trunc('minute', observed_at) AS time,\r\n  COUNT(*) FILTER (WHERE status = 'UP')::bigint AS up,\r\n  COUNT(*) FILTER (WHERE status = 'DEGRADED')::bigint AS degraded,\r\n  COUNT(*) FILTER (WHERE status = 'DOWN')::bigint AS down,\r\n  COUNT(*) FILTER (WHERE status = 'UNKNOWN')::bigint AS unknown\r\nFROM monitoring.service_checks\r\nWHERE observed_at BETWEEN $__timeFrom() AND $__timeTo()\r\nGROUP BY 1\r\nORDER BY 1;\r\n",
